
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Local Community Event Portal</title>

    <style>
        #welcomeBanner {
            background-color: blue;
            color: white;
            padding: 15px;
            text-align: center;
        }

        .highlight {
            background-color: yellow;
            font-weight: bold;
        }

        .eventImage {
            border: 2px solid black;
            width: 200px;
            height: 120px;
        }

        form {
            width: 50%;
            margin: auto;
        }
    </style>
</head>

<body>

    <nav>
        <a href="#home">Home</a> |
        <a href="#events">Events</a> |
        <a href="#contact">Contact</a> |
        <a href="help.html" target="_blank">Help</a>
    </nav>

    <hr>

   

    <section id="home">
        <div id="welcomeBanner">
            <h1>Welcome to Local Community Event Portal</h1>

            <p>
                Special Offer:
                <span style="color:red; font-weight:bold;">
                    Register Today and Get Free Entry!
                </span>
            </p>

            <p class="highlight">
                Stay connected with your community.
            </p>
        </div>
    </section>

    <hr>

    
    <section id="events">
        <h2>Community Events Gallery</h2>

        <table border="1">
            <tr>
                <td>
                    <img src="images/event1.jpg" alt="Event 1" title="Community Fair" class="eventImage">
                    <p>Community Fair</p>
                </td>

                <td>
                    <img src="images/event2.jpg" alt="Event 2" title="Health Camp" class="eventImage">
                    <p>Health Camp</p>
                </td>

                <td>
                    <img src="images/event3.jpg" alt="Event 3" title="Clean Up Drive" class="eventImage">
                    <p>Clean Up Drive</p>
                </td>
            </tr>

            <tr>
                <td>
                    <img src="images/event4.jpg" alt="Event 4" title="Sports Meet" class="eventImage">
                    <p>Sports Meet</p>
                </td>

                <td>
                    <img src="images/event5.jpg" alt="Event 5" title="Food Festival" class="eventImage">
                    <p>Food Festival</p>
                </td>

                <td>
                    <img src="images/event6.jpg" alt="Event 6" title="Cultural Program" class="eventImage">
                    <p>Cultural Program</p>
                </td>
            </tr>
        </table>
    </section>

    <hr>

    

    <section>
        <h2>Event Registration</h2>

        <form>

            <label>Name:</label><br>
            <input type="text" placeholder="Enter your name" required autofocus><br><br>

            <label>Email:</label><br>
            <input type="email" placeholder="Enter your email" required><br><br>

            <label>Event Date:</label><br>
            <input type="date" required><br><br>

            <label>Event Type:</label><br>
            <select>
                <option>Community Fair</option>
                <option>Health Camp</option>
                <option>Sports Meet</option>
            </select><br><br>

            <label>Message:</label><br>
            <textarea placeholder="Enter your message"></textarea><br><br>

            <button type="submit">Register</button>

            <br><br>

            <output>
                Registration Successful!
            </output>

        </form>
    </section>

    <hr>

  

    <section>
        <h2>Event Feedback</h2>

        <label>Phone Number:</label><br>
        <input type="text" onblur="validatePhone()"><br><br>

        <label>Select Event:</label><br>
        <select onchange="showFee()">
            <option>Community Fair</option>
            <option>Health Camp</option>
            <option>Sports Meet</option>
        </select>

        <p id="fee"></p>

        <button onclick="submitForm()">
            Submit
        </button>

        <br><br>

        <img src="images/event1.jpg"
             width="200"
             ondblclick="enlargeImage()"
             alt="Event Image">

        <br><br>

        <textarea id="feedbackBox"
                  onkeyup="countCharacters()"
                  placeholder="Type feedback">
        </textarea>

        <p id="count">Characters: 0</p>

    </section>

    <hr>

    

    <section>
        <h2>Event Promo Video</h2>

        <video width="400" controls oncanplay="videoReady()">
            <source src="video/event.mp4" type="video/mp4">
        </video>

        <p id="videoMessage"></p>
    </section>

    <hr>

    <!-- User Preferences -->

    <section>
        <h2>Save Event Preference</h2>

        <select id="eventPreference">
            <option>Community Fair</option>
            <option>Health Camp</option>
            <option>Sports Meet</option>
        </select>

        <button onclick="savePreference()">
            Save Preference
        </button>

        <button onclick="clearPreference()">
            Clear Preferences
        </button>
    </section>

    <hr>

    <!-- Geolocation -->

    <section>
        <h2>Find Nearby Events</h2>

        <button onclick="findLocation()">
            Find Nearby Events
        </button>

        <p id="location"></p>
    </section>

    <hr>

    <!-- Contact -->

    <section id="contact">
        <h2>Contact Us</h2>
        <p>Email: communityportal@gmail.com</p>
        <p>Phone: +91 9876543210</p>
    </section>

    <!-- Footer -->

    <footer>
        <hr>
        <p>&copy; 2026 Local Community Event Portal</p>
    </footer>

    <script>
        function validatePhone() {
            alert("Phone validation triggered");
        }

        function showFee() {
            document.getElementById("fee").innerHTML =
                "Selected Event Fee: ₹200";
        }

        function submitForm() {
            alert("Registration Submitted");
        }

        function enlargeImage() {
            alert("Image Enlarged");
        }

        function countCharacters() {
            let text =
                document.getElementById("feedbackBox").value;

            document.getElementById("count").innerHTML =
                "Characters: " + text.length;
        }

        function videoReady() {
            document.getElementById("videoMessage").innerHTML =
                "Video Ready to Play";
        }

        function savePreference() {
            let value =
                document.getElementById("eventPreference").value;

            localStorage.setItem("preferredEvent", value);

            alert("Preference Saved");
        }

        function clearPreference() {
            localStorage.clear();
            sessionStorage.clear();

            alert("Preferences Cleared");
        }

        function findLocation() {

            navigator.geolocation.getCurrentPosition(
                function(position) {

                    document.getElementById("location").innerHTML =
                        "Latitude: " +
                        position.coords.latitude +
                        "<br>Longitude: " +
                        position.coords.longitude;

                },

                function(error) {
                    alert("Location Access Denied");
                },

                {
                    enableHighAccuracy: true,
                    timeout: 5000
                }
            );
        }

        window.onbeforeunload = function() {
            return "Are you sure you want to leave?";
        };
    </script>

</body>
</html>
```

